<Window x:Class="BossKey.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="&#x8001;&#x677F;&#x952E;"
        Width="1120"
        Height="820"
        MinWidth="1120"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7FB">
    <Window.Resources>
        <Style x:Key="CardButtonStyle" TargetType="Button">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#213042" />
            <Setter Property="Background" Value="#EEF3F8" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource CardButtonStyle}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#1447E6" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="GridTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True">
                    <Setter Property="Foreground" Value="White" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SlimScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Margin="2,1"
                                Background="#C8D4E3"
                                CornerRadius="4" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="7" />
            <Setter Property="Height" Value="7" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Opacity="0"
                                                  Focusable="False" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SlimScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Opacity="0"
                                                  Focusable="False" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="7" />
                    <Setter Property="Width" Value="Auto" />
                </Trigger>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="7" />
                    <Setter Property="Height" Value="Auto" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#EDF1F7" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGrid">
                        <Border Background="{TemplateBinding Background}" CornerRadius="16">
                            <ScrollViewer Focusable="False" Padding="0">
                                <ItemsPresenter />
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F7F9FC" />
            <Setter Property="Foreground" Value="#5F6B7A" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White" />
            <Setter Property="Height" Value="34" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FBFF" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EAF2FF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="Foreground" Value="#18212F" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="0.95*" />
            </Grid.ColumnDefinitions>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

            <Border Padding="18" CornerRadius="22" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#18212F"
                                       Text="&#x6309;&#x8F6F;&#x4EF6;&#x540D;&#x79F0;&#x9690;&#x85CF;" />
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="12"
                                       Foreground="#657284"
                                       Text="&#x53CC;&#x51FB;&#x4E0B;&#x9762;&#x7684;&#x8F6F;&#x4EF6;&#x540D;&#x79F0;&#x53EF;&#x4EE5;&#x52A0;&#x5165;&#x4FDD;&#x5B58;&#x5217;&#x8868;&#x3002;" />
                        </StackPanel>

                        <Button Grid.Column="2"
                                MinWidth="150"
                                Height="34"
                                VerticalAlignment="Center"
                                Click="RefreshProcessesButton_Click"
                                Style="{StaticResource CardButtonStyle}"
                                Content="&#x5237;&#x65B0;&#x8F6F;&#x4EF6;&#x540D;&#x79F0;" />
                    </Grid>

                    <DataGrid Grid.Row="2"
                              Style="{StaticResource ModernDataGridStyle}"
                              ItemsSource="{Binding ProcessItems}"
                              IsReadOnly="True"
                              MouseDoubleClick="ProcessSourceGrid_MouseDoubleClick"
                              AlternatingRowBackground="#FCFDFE">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="*"
                                                Binding="{Binding ProcessName}"
                                                ElementStyle="{StaticResource GridTextStyle}"
                                                Header="&#x8F6F;&#x4EF6;&#x540D;&#x79F0;" />
                            <DataGridTextColumn Width="90"
                                                Binding="{Binding WindowCount}"
                                                ElementStyle="{StaticResource GridTextStyle}"
                                                Header="&#x7A97;&#x53E3;&#x6570;" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Row="2" Padding="18" CornerRadius="22" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#18212F"
                                   Text="&#x5DF2;&#x4FDD;&#x5B58;&#x7684;&#x8F6F;&#x4EF6;&#x540D;&#x79F0;" />
                        <TextBlock Margin="0,4,0,0"
                                   FontSize="12"
                                   Foreground="#657284"
                                   Text="&#x53CC;&#x51FB;&#x5DF2;&#x4FDD;&#x5B58;&#x9879;&#x53EF;&#x4EE5;&#x79FB;&#x9664;&#x3002;" />
                    </StackPanel>

                    <DataGrid Grid.Row="2"
                              Style="{StaticResource ModernDataGridStyle}"
                              ItemsSource="{Binding SavedProcessItems}"
                              IsReadOnly="True"
                              MouseDoubleClick="SavedProcessGrid_MouseDoubleClick"
                              AlternatingRowBackground="#FCFDFE">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="*"
                                                Binding="{Binding ProcessName}"
                                                ElementStyle="{StaticResource GridTextStyle}"
                                                Header="&#x8F6F;&#x4EF6;&#x540D;&#x79F0;" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

            <Border Padding="18" CornerRadius="22" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#18212F"
                                       Text="&#x6309;&#x7A97;&#x53E3;&#x6807;&#x9898;&#x9690;&#x85CF;" />
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="12"
                                       Foreground="#657284"
                                       Text="&#x53CC;&#x51FB;&#x4E0B;&#x9762;&#x7684;&#x7A97;&#x53E3;&#x6807;&#x9898;&#x53EF;&#x4EE5;&#x52A0;&#x5165;&#x4FDD;&#x5B58;&#x5217;&#x8868;&#x3002;" />
                        </StackPanel>

                        <Button Grid.Column="2"
                                MinWidth="150"
                                Height="34"
                                VerticalAlignment="Center"
                                Click="RefreshTitlesButton_Click"
                                Style="{StaticResource CardButtonStyle}"
                                Content="&#x5237;&#x65B0;&#x7A97;&#x53E3;&#x6807;&#x9898;" />
                    </Grid>

                    <DataGrid Grid.Row="2"
                              Style="{StaticResource ModernDataGridStyle}"
                              ItemsSource="{Binding WindowItems}"
                              IsReadOnly="True"
                              MouseDoubleClick="WindowSourceGrid_MouseDoubleClick"
                              AlternatingRowBackground="#FCFDFE">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="140"
                                                Binding="{Binding ProcessName}"
                                                ElementStyle="{StaticResource GridTextStyle}"
                                                Header="&#x8F6F;&#x4EF6;&#x540D;&#x79F0;" />
                            <DataGridTextColumn Width="*"
                                                Binding="{Binding Title}"
                                                ElementStyle="{StaticResource GridTextStyle}"
                                                Header="&#x7A97;&#x53E3;&#x6807;&#x9898;" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Row="2" Padding="18" CornerRadius="22" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#18212F"
                                   Text="&#x5DF2;&#x4FDD;&#x5B58;&#x7684;&#x7A97;&#x53E3;&#x6807;&#x9898;" />
                        <TextBlock Margin="0,4,0,0"
                                   FontSize="12"
                                   Foreground="#657284"
                                   Text="&#x53CC;&#x51FB;&#x5DF2;&#x4FDD;&#x5B58;&#x9879;&#x53EF;&#x4EE5;&#x79FB;&#x9664;&#x3002;" />
                    </StackPanel>

                    <DataGrid Grid.Row="2"
                              Style="{StaticResource ModernDataGridStyle}"
                              ItemsSource="{Binding SavedWindowItems}"
                              IsReadOnly="True"
                              MouseDoubleClick="SavedWindowGrid_MouseDoubleClick"
                              AlternatingRowBackground="#FCFDFE">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="140"
                                                Binding="{Binding ProcessName}"
                                                ElementStyle="{StaticResource GridTextStyle}"
                                                Header="&#x8F6F;&#x4EF6;&#x540D;&#x79F0;" />
                            <DataGridTextColumn Width="*"
                                                Binding="{Binding Title}"
                                                ElementStyle="{StaticResource GridTextStyle}"
                                                Header="&#x7A97;&#x53E3;&#x6807;&#x9898;" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
            </Grid>

            <Border Grid.Column="4" Padding="18" CornerRadius="22" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#18212F"
                               Text="&#x8001;&#x677F;&#x952E;&#x8BBE;&#x7F6E;" />

                    <TextBlock Grid.Row="2"
                               FontSize="12"
                               Foreground="#657284"
                               Text="&#x8001;&#x677F;&#x952E;" />

                    <Border Grid.Row="4"
                            Height="42"
                            Padding="12,0"
                            CornerRadius="12"
                            Background="#F7F9FC"
                            BorderBrush="#D8E1EE"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox BorderThickness="0"
                                     Background="Transparent"
                                     VerticalContentAlignment="Center"
                                     FontSize="14"
                                     FontWeight="SemiBold"
                                     Foreground="#18212F"
                                     CaretBrush="Transparent"
                                     IsReadOnly="True"
                                     PreviewKeyDown="BossHotKeyCaptureBox_PreviewKeyDown"
                                     GotFocus="BossHotKeyCaptureBox_GotFocus"
                                     LostFocus="BossHotKeyCaptureBox_LostFocus"
                                     Text="{Binding BossHotKeyEditorText}" />

                            <TextBlock Grid.Column="1"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="#657284"
                                       FontSize="12"
                                       Text="&#x70B9;&#x51FB;&#x540E;&#x76F4;&#x63A5;&#x6309;&#x952E;" />
                        </Grid>
                    </Border>

                    <Button Grid.Row="6"
                            Height="38"
                            Click="SaveBossHotKeyButton_Click"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Content="&#x4FDD;&#x5B58;&#x8001;&#x677F;&#x952E;" />

                    <TextBlock Grid.Row="8"
                               FontSize="12"
                               Foreground="#657284"
                               Text="&#x9690;&#x85CF;&#x81EA;&#x8EAB;&#x5FEB;&#x6377;&#x952E;" />

                    <Border Grid.Row="10"
                            Height="42"
                            Padding="12,0"
                            CornerRadius="12"
                            Background="#F7F9FC"
                            BorderBrush="#D8E1EE"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox BorderThickness="0"
                                     Background="Transparent"
                                     VerticalContentAlignment="Center"
                                     FontSize="14"
                                     FontWeight="SemiBold"
                                     Foreground="#18212F"
                                     CaretBrush="Transparent"
                                     IsReadOnly="True"
                                     PreviewKeyDown="SelfHotKeyCaptureBox_PreviewKeyDown"
                                     GotFocus="SelfHotKeyCaptureBox_GotFocus"
                                     LostFocus="SelfHotKeyCaptureBox_LostFocus"
                                     Text="{Binding SelfHotKeyEditorText}" />

                            <TextBlock Grid.Column="1"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="#657284"
                                       FontSize="12"
                                       Text="&#x70B9;&#x51FB;&#x540E;&#x76F4;&#x63A5;&#x6309;&#x952E;" />
                        </Grid>
                    </Border>

                    <Button Grid.Row="12"
                            Height="38"
                            Click="SaveSelfHotKeyButton_Click"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Content="&#x4FDD;&#x5B58;&#x81EA;&#x8EAB;&#x5FEB;&#x6377;&#x952E;" />

                    <Border Grid.Row="14" Padding="14" CornerRadius="16" Background="#F6F9FC">
                        <StackPanel>
                            <TextBlock FontSize="12"
                                       Foreground="#657284"
                                       Text="&#x5F53;&#x524D;&#x72B6;&#x6001;" />
                            <TextBlock Margin="0,6,0,0"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#18212F"
                                       Text="{Binding BossModeText}" />
                            <TextBlock Margin="0,6,0,0"
                                       FontSize="12"
                                       Foreground="#657284"
                                       Text="{Binding BossHotKeyText}" />
                            <TextBlock Margin="0,6,0,0"
                                       FontSize="12"
                                       Foreground="#657284"
                                       Text="{Binding SelfHotKeyText}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="16" Padding="14" CornerRadius="16" Background="#FFF9EB">
                        <TextBlock TextWrapping="Wrap"
                                   FontSize="12"
                                   Foreground="#715B1B"
                                   Text="&#x8001;&#x677F;&#x952E;&#x53EA;&#x9690;&#x85CF;&#x6216;&#x6062;&#x590D;&#x76EE;&#x6807;&#x7A97;&#x53E3;&#x3002;&#x9690;&#x85CF;&#x81EA;&#x8EAB;&#x5FEB;&#x6377;&#x952E;&#x4EC5;&#x5F71;&#x54CD;&#x672C;&#x7A0B;&#x5E8F;&#x81EA;&#x8EAB;&#x3002;" />
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Padding="16" CornerRadius="18" Background="#142033">
            <TextBlock FontSize="13" Foreground="#E8EDF5" Text="{Binding StatusText}" />
        </Border>
    </Grid>
</Window>
